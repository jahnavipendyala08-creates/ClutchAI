rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /tasks/{document} {
      allow read, write: if true;
    }
    match /bills/{document} {
      allow read, write: if true;
    }
    match /schedule/{document} {
      allow read, write: if true;
    }
    match /profile/{document} {
      allow read, write: if true;
    }
    match /settings/{document} {
      allow read, write: if true;
    }
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
